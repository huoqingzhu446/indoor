NODE_ENV=production

NGINX_HTTP_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=room_ai
POSTGRES_USER=room_ai
POSTGRES_PASSWORD=replace_with_a_strong_database_password
DATABASE_URL=postgresql://room_ai:replace_with_a_strong_database_password@postgres:5432/room_ai

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=replace_with_minio_admin
MINIO_ROOT_PASSWORD=replace_with_a_strong_minio_password
OSS_ENDPOINT=http://minio:9000
OSS_PUBLIC_BASE_URL=http://YOUR_SERVER_IP/static
OSS_BUCKET_PUBLIC=room-ai-public
OSS_BUCKET_PRIVATE=room-ai-private
OSS_ACCESS_KEY=replace_with_minio_admin
OSS_SECRET_KEY=replace_with_a_strong_minio_password

APP_BASE_URL=http://YOUR_SERVER_IP
PUBLIC_WEB_BASE_URL=http://YOUR_SERVER_IP
VITE_API_BASE_URL=http://YOUR_SERVER_IP/api
VITE_STATIC_BASE_URL=http://YOUR_SERVER_IP/static
AI_SERVICE_BASE_URL=http://ai-service:8000
API_BASE_URL=http://api:3000

JWT_SECRET=replace_with_a_long_random_string
INTERNAL_SERVICE_TOKEN=replace_with_an_internal_service_token

MINIMAX_API_BASE=https://api.minimaxi.com/v1
MINIMAX_API_KEY=replace_with_your_minimax_api_key
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01-live
MINIMAX_CALLBACK_SECRET=replace_with_a_callback_secret
MINIMAX_MOCK_MODE=false
MINIMAX_USE_IMAGE_REFERENCE=false
