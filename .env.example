NODE_ENV=development

NGINX_HTTP_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=room_ai
POSTGRES_USER=room_ai
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://room_ai:change_me@postgres:5432/room_ai

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OSS_ENDPOINT=http://minio:9000
OSS_PUBLIC_BASE_URL=http://127.0.0.1:9000
OSS_BUCKET_PUBLIC=room-ai-public
OSS_BUCKET_PRIVATE=room-ai-private
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin

APP_BASE_URL=http://localhost
PUBLIC_WEB_BASE_URL=http://localhost:5175
VITE_API_BASE_URL=http://localhost/api
VITE_STATIC_BASE_URL=http://localhost/static
AI_SERVICE_BASE_URL=http://ai-service:8000
API_BASE_URL=http://api:3000

JWT_SECRET=replace_with_a_long_random_string
INTERNAL_SERVICE_TOKEN=replace_with_internal_service_token

MINIMAX_API_BASE=https://api.minimaxi.com/v1
MINIMAX_API_KEY=replace_with_minimax_api_key
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01-live
MINIMAX_CALLBACK_SECRET=replace_with_callback_secret
MINIMAX_MOCK_MODE=false
MINIMAX_USE_IMAGE_REFERENCE=false
